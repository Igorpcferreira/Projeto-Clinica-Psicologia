@startuml MER_Conceitual_Clinica_Psicologia
' Modelo Entidade-Relacionamento CONCEITUAL — Sistema de Gestao para Clinica de Psicologia
' Autor: Joao Pedro Goncalves Ferreira
' Revisao Entrega 2: modelo CONCEITUAL (sem chaves), relacionamentos NOMEADOS.
'
' IMPORTANTE (feedback da professora):
'   - Este e o modelo CONCEITUAL: entidades + atributos descritivos + relacionamentos
'     nomeados com cardinalidade. NAO ha chave primaria nem chave estrangeira aqui.
'   - A migracao para o modelo RELACIONAL (com PK/FK) e a proxima etapa e esta em MER.dbml.
'   - Escopo desta entrega: agendamento/atendimento/prontuario/comunicacao.
'     Entidades financeiras (Pagamento, Recibo) ficam para a evolucao futura.
'
' Para gerar PNG: java -jar plantuml.jar MER_Conceitual.puml

skinparam linetype ortho
left to right direction
hide circle
skinparam class {
  BackgroundColor #F8FAFC
  BorderColor #2563EB
}

' ============== Identidade e acesso ==============
entity Usuario {
  email
  nome
  ativo
  mfa_habilitado
}

entity Papel {
  nome  ' ADMIN | PROFISSIONAL | SECRETARIA | PACIENTE
}

' ============== Dominio clinico ==============
entity Clinica {
  razao_social
  cnpj
  endereco
  telefone
}

entity Profissional {
  crp
  bio
  ativo
  permite_autoagendamento
}

entity Especialidade {
  nome
}

entity AgendaConfig {
  dia_semana
  hora_inicio
  hora_fim
  duracao_slot
}

entity Sala {
  nome
  tipo          ' INDIVIDUAL | MULTIDISCIPLINAR
  capacidade
}

entity Paciente {
  nome
  cpf
  data_nascimento
  email
  telefone
  canal_preferido_lembrete
}

' ============== Agendamento e atendimento ==============
entity Agendamento {
  inicio
  fim
  modalidade    ' PRESENCIAL | ONLINE
  tipo_sessao   ' ANAMNESE | RETORNO | AVALIACAO | GRUPAL
  status        ' AGENDADO | CONFIRMADO | REALIZADO | CANCELADO | FALTOU
  recorrencia
}

entity Atendimento {
  iniciado_em
  finalizado_em
  duracao_min
  presenca      ' PRESENTE | FALTOU
  observacoes
}

' ============== Prontuario ==============
entity Prontuario {
  aberto_em
  encerrado_em
}

entity EvolucaoSessao {
  tipo          ' ANAMNESE | SESSAO_REGULAR | RETORNO | AVALIACAO | ALTA | ENCAMINHAMENTO | CORRECAO
  texto         ' criptografado em repouso
  registrado_em
}

entity Anexo {
  nome_arquivo
  tipo
  tamanho
}

' ============== Comunicacao ==============
entity Lembrete {
  canal         ' WHATSAPP | EMAIL
  agendar_para
  status        ' PENDENTE | ENVIADO | CONFIRMADO | FALHADO | REENVIO
}

entity TemplateMensagem {
  tipo          ' LEMBRETE_24H | LEMBRETE_2H | CONFIRMACAO
  canal
  conteudo
}

' ============== LGPD e auditoria ==============
entity ConsentimentoLGPD {
  versao_termo
  aceito_em
  revogado_em
}

entity LogAuditoria {
  acao
  entidade
  registrado_em
  severidade
}

' ============== Relacionamentos NOMEADOS (cardinalidade) ==============
Usuario "1" -- "0..*" Papel : possui >
Usuario "1" -- "0..1" Profissional : e >
Usuario "1" -- "0..1" Paciente : e >
Clinica "1" -- "0..*" Profissional : emprega >
Profissional "0..*" -- "1..*" Especialidade : atua_em >
Profissional "1" -- "0..*" AgendaConfig : define >
Clinica "1" -- "0..*" Sala : possui >
Profissional "0..*" -- "0..*" Paciente : acompanha >

Paciente "1" -- "0..*" Agendamento : solicita >
Profissional "1" -- "0..*" Agendamento : atende_em >
Sala "1" -- "0..*" Agendamento : sedia >
Agendamento "1" -- "0..1" Atendimento : gera >

Paciente "1" -- "1" Prontuario : possui >
Profissional "1" -- "1" Prontuario : responsavel_por >
Prontuario "1" -- "0..*" EvolucaoSessao : contem >
Profissional "1" -- "0..*" EvolucaoSessao : registra >
Atendimento "1" -- "0..1" EvolucaoSessao : documenta >
EvolucaoSessao "1" -- "0..*" Anexo : anexa >
EvolucaoSessao "0..1" -- "0..*" EvolucaoSessao : corrige >

Agendamento "1" -- "0..*" Lembrete : programa >
Clinica "1" -- "0..*" TemplateMensagem : mantem >

Paciente "1" -- "0..*" ConsentimentoLGPD : concede >
Usuario "1" -- "0..*" LogAuditoria : origina >

@enduml
